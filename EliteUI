					or ""
				ActionButton.Header.Icon.Visible = not String.IsEmptyOrNull(Action.Icon)
				ActionButton.Header.Header.Text = Action.Name

				-- Make sure all layers can receive mouse events
				pcall(function() ActionButton.Active = true end)
				pcall(function() ActionButton.Backdrop.Active = true end)
				pcall(function() ActionButton.Interactable = true end)
				pcall(function() ActionButton.Backdrop.Interactable = true end)

				-- Identical hover/leave for both buttons тАФ accent appears on hover
				local function onHover()
					Tween(ActionButton.Backdrop, { BackgroundTransparency = 0.15 })
					pcall(function()
						ActionButton.Backdrop.Accent.Enabled = true
						ActionButton.Backdrop.UIStroke.Accent.Enabled = true
						Tween(ActionButton.Backdrop.UIStroke, { Transparency = 0.3 })
					end)
					Tween(ActionButton.Header.Header, { TextColor3 = EliteUI.CurrentTheme.Foregrounds.Active })
					pcall(function()
						Tween(ActionButton.Header.Icon, { ImageColor3 = EliteUI.CurrentTheme.Foregrounds.Active })
					end)
				end
				local function onLeave()
					Tween(ActionButton.Backdrop, { BackgroundTransparency = 0 })
					pcall(function()
						ActionButton.Backdrop.Accent.Enabled = false
						ActionButton.Backdrop.UIStroke.Accent.Enabled = false
						Tween(ActionButton.Backdrop.UIStroke, { Transparency = 0 })
					end)
					Tween(ActionButton.Header.Header, { TextColor3 = EliteUI.CurrentTheme.Foregrounds.Light })
					pcall(function()
						Tween(ActionButton.Header.Icon, { ImageColor3 = EliteUI.CurrentTheme.Foregrounds.Light })
					end)
				end

				-- Connect hover on both button and backdrop to cover all cases
				ActionButton.MouseEnter:Connect(onHover)
				ActionButton.MouseLeave:Connect(onLeave)
				pcall(function()
					ActionButton.Backdrop.MouseEnter:Connect(onHover)
					ActionButton.Backdrop.MouseLeave:Connect(onLeave)
				end)

				ActionButton.MouseButton1Click:Connect(function()
					close(function()
						local Success, Response = pcall(Action.Callback)

						if not Success then
							warn(`EliteUI - Callback Error | Dialog {Modal.Values.Name}`)
							if WindowSettings.NotifyOnCallbackError then
								EliteUI:Notification({
									Title = Modal.Values.Name .. " Callback Error",

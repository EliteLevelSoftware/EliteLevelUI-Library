            local pos = subMain.AbsolutePosition
            local sz  = subMain.AbsoluteSize
            local HP, CP = SUB_HP, SUB_CP
            subHandles.right.Size     = UDim2.fromOffset(HP, sz.Y-CP*2);  subHandles.right.Position  = UDim2.fromOffset(pos.X+sz.X,       pos.Y+CP)
            subHandles.left.Size      = UDim2.fromOffset(HP, sz.Y-CP*2);  subHandles.left.Position   = UDim2.fromOffset(pos.X-HP,          pos.Y+CP)
            subHandles.bottom.Size    = UDim2.fromOffset(sz.X-CP*2, HP);  subHandles.bottom.Position = UDim2.fromOffset(pos.X+CP,          pos.Y+sz.Y)
            subHandles.top.Size       = UDim2.fromOffset(sz.X-CP*2, HP);  subHandles.top.Position    = UDim2.fromOffset(pos.X+CP,          pos.Y-HP)
            subHandles.br.Size        = UDim2.fromOffset(CP, CP);         subHandles.br.Position     = UDim2.fromOffset(pos.X+sz.X-CP,     pos.Y+sz.Y-CP)
            subHandles.bl.Size        = UDim2.fromOffset(CP, CP);         subHandles.bl.Position     = UDim2.fromOffset(pos.X-HP,          pos.Y+sz.Y-CP)
            subHandles.tr.Size        = UDim2.fromOffset(CP, CP);         subHandles.tr.Position     = UDim2.fromOffset(pos.X+sz.X-CP,     pos.Y-HP)

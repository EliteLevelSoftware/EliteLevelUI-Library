-- Rayfield:CreateSubWindow(settings)
-- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
-- Creates a second independent EliteUI window instance.
-- Identical look, theme, transparency, and widget API to the main window.
-- Returns a WindowWrapper тАФ use exactly like the main Window object.
--
-- settings = {
--     Name            = string,
--     LoadingTitle    = string,
--     LoadingSubtitle = string,
--     Icon            = string/number,
-- }

function Rayfield:CreateSubWindow(settings)
    settings = settings or {}

    -- Load a fresh copy of the model asset
    local subModelId = debugV and 136653172778765 or 90058405618888
    local subInst = isStudio
        and script.Parent:WaitForChild("EliteUI V1"):Clone()
        or game:GetObjects("rbxassetid://" .. subModelId)[1]

    subInst.Name = "EliteUI_SubWindow_" .. (settings.Name or "SubWindow")

    -- Strip scripts/physics from model
    for _, obj in ipairs(subInst:GetDescendants()) do
        if obj:IsA("LocalScript") or obj:IsA("Script") or obj:IsA("ModuleScript")
        or obj:IsA("BasePart") or obj:IsA("Model") or obj:IsA("Attachment")
        or obj:IsA("Constraint") or obj:IsA("BodyMover") then
            pcall(function() obj:Destroy() end)
        end
    end

    -- Parent to same place as main window
    if gethui then
        subInst.Parent = gethui()
    elseif syn and syn.protect_gui then
        syn.protect_gui(subInst)
        subInst.Parent = game:GetService("CoreGui")
    else
        subInst.Parent = game:GetService("CoreGui")
    end

    pcall(function() subInst.OnTopOfCoreBlur = true end)
    subInst.Enabled = true

    -- Position offset from main window so they don't overlap
    local subMain = subInst.MainWindow
    subMain.AnchorPoint = Vector2.zero
    subMain.Position = UDim2.fromOffset(
        Camera.ViewportSize.X / 2 - subMain.Size.X.Offset / 2 + 40,
        (Camera.ViewportSize.Y / 2 - GuiInset - subMain.Size.Y.Offset / 2) - GuiInset/2 + 40
    )
    subMain.Visible = true

    -- Apply current theme to sub window
    -- We reuse themeEvent so sub window updates when user changes theme
    local subThemeMethods = {
        bindTheme = function(_, object, property, themeKey)
            local function set()
                if not object or not object.Parent then return end
                pcall(function()
                    if object.ClassName == "UIGradient"
                    and typeof(GetNestedValue(EliteUI.CurrentTheme, themeKey)) == "Color3" then
                        object[property] = ColorSequence.new({
                            ColorSequenceKeypoint.new(0, GetNestedValue(EliteUI.CurrentTheme, themeKey)),
                            ColorSequenceKeypoint.new(1, GetNestedValue(EliteUI.CurrentTheme, themeKey)),
                        })
                        return
                    end
                    object[property] = GetNestedValue(EliteUI.CurrentTheme, themeKey)
                end)
            end
            themeEvent.Event:Connect(set)
            set()
        end
    }

    -- Bind all the same theme keys as main window
    local subNav    = subMain.Sidebar.Navigation
    local subTabs   = subMain.Content.ContentMain.Elements
    local subDrag   = subInst:FindFirstChild("Drag")

    do
        subThemeMethods:bindTheme(subMain,            "BackgroundColor3", "Backgrounds.Dark")
        subThemeMethods:bindTheme(subMain.UIStroke.Accent, "Color",       "Accents.Brighter")
        for _, s in ipairs(subMain.DropShadowHolder:GetChildren()) do
            subThemeMethods:bindTheme(s, "ImageColor3", "Miscellaneous.Shadow")
        end
        subThemeMethods:bindTheme(subMain.ModalOverlay,   "BackgroundColor3", "Backgrounds.Groupbox")
        subThemeMethods:bindTheme(subMain.Sidebar,        "BackgroundColor3", "Backgrounds.Light")
        for _, cr in ipairs(subMain.Sidebar.CornerRepairs:GetChildren()) do
            subThemeMethods:bindTheme(cr, "ImageColor3", "Backgrounds.Light")
        end
        subThemeMethods:bindTheme(subMain.Sidebar.DropShadowHolder.DropShadow, "ImageColor3", "Foregrounds.Dark")
        subThemeMethods:bindTheme(subMain.Sidebar.Header, "TextColor3",        "Foregrounds.Active")
        subThemeMethods:bindTheme(subMain.Sidebar.Player.PlayerIcon, "BackgroundColor3", "Backgrounds.Groupbox")
        subThemeMethods:bindTheme(subMain.Sidebar.Player.Header,     "TextColor3",       "Foregrounds.Light")
        subThemeMethods:bindTheme(subMain.Sidebar.Player.subheader,  "TextColor3",       "Foregrounds.Medium")
        subThemeMethods:bindTheme(subMain.Content.Topbar, "BackgroundColor3", "Backgrounds.Medium")
        for _, cr in ipairs(subMain.Content.Topbar.CornerRepairs:GetChildren()) do
            subThemeMethods:bindTheme(cr, "ImageColor3", "Backgrounds.Medium")
        end
        subThemeMethods:bindTheme(subMain.Content.Topbar.Headers.Subheader, "TextColor3", "Foregrounds.Medium")
        subThemeMethods:bindTheme(subMain.Content.ContentMain, "BackgroundColor3", "Backgrounds.Dark")
        for _, cr in ipairs(subMain.Content.ContentMain.CornerRepairs:GetChildren()) do
            subThemeMethods:bindTheme(cr, "ImageColor3", "Backgrounds.Dark")
        end

    end

    -- Set window title, hide icon, player section, and topbar subheader
    subMain.Sidebar.Header.Text = settings.Name or "Sub Window"
    -- Hide the brand icon (top of sidebar) and the inline header icon
    pcall(function() subMain.Sidebar.Icon.Visible = false end)
    pcall(function() subMain.Sidebar.Icon.Image = "" end)
    pcall(function() subMain.Sidebar.Header.Icon.Visible = false end)
    pcall(function() subMain.Sidebar.Header.UIPadding.PaddingLeft = UDim.new(0, 8) end)
    pcall(function() subMain.Sidebar.Player.Visible = false end)
    pcall(function() subMain.Content.Topbar.Headers.Subheader.Text = "" end)
    pcall(function() subMain.Content.Topbar.Headers.Subheader.Visible = false end)

    -- Hide loading screen immediately
    pcall(function() subMain["New Loading Screen"].Visible = false end)

    -- Sync transparency with main window тАФ identical logic to main window's transparencyEvent handler
    -- Only applies to the background panels (mainWindow, sidebar, topbar, contentMain)
    -- Never touches text, icons, or UI element content
    local function applySubTransparency()
        local themeAlpha = 0
        if EliteUI.CurrentTheme and EliteUI.CurrentTheme.Transparency then
            themeAlpha = EliteUI.CurrentTheme.Transparency
        end
        if transparencyOverride ~= nil then
            themeAlpha = transparencyOverride
        end

        local baseT    = themeAlpha
        local topbarT  = themeAlpha * 0.85
        local sidebarT = themeAlpha * 0.75

        Tween(subMain,                          { BackgroundTransparency = baseT })
        Tween(subMain.Content.ContentMain,      { BackgroundTransparency = baseT })
        Tween(subMain.Content.Topbar,           { BackgroundTransparency = topbarT })
        Tween(subMain.Sidebar,                  { BackgroundTransparency = sidebarT })
        for _, cr in ipairs(subMain.Content.ContentMain.CornerRepairs:GetChildren()) do
            Tween(cr, { ImageTransparency = baseT })
        end
        for _, cr in ipairs(subMain.Content.Topbar.CornerRepairs:GetChildren()) do
            Tween(cr, { ImageTransparency = topbarT })
        end
        for _, cr in ipairs(subMain.Sidebar.CornerRepairs:GetChildren()) do
            Tween(cr, { ImageTransparency = sidebarT })
        end
    end

    transparencyEvent.Event:Connect(applySubTransparency)
    task.defer(applySubTransparency)

    -- Register this sub window so main window can close/toggle it
    table.insert(EliteUI.SubWindows, subInst)
    subInst.Destroying:Connect(function()
        for i, sw in ipairs(EliteUI.SubWindows) do
            if sw == subInst then
                table.remove(EliteUI.SubWindows, i)
                break
            end
        end
    end)

    -- Drag via topbar тАФ sub windows have no Drag cosmetic, pass nil
    pcall(function()
        makeDraggable(subMain.Content.Topbar, subMain, nil, false, nil)
    end)

    -- Wire all topbar controls тАФ identical behavior and theming to main window
    pcall(function()
        -- Theme all control buttons the same way as main window
        for _, control in pairs(subMain.Content.Topbar.Controls:GetChildren()) do
            if control.ClassName == "TextButton" then
                subThemeMethods:bindTheme(control, "BackgroundColor3", "Foregrounds.Dark")
                control.MouseEnter:Connect(function()
                    Tween(control.Fill, { BackgroundTransparency = 0 })

				local order = 0
				for _, stat in ipairs(leaderstats:GetChildren()) do
					if stat:IsA("ValueBase") or stat:IsA("IntValue") or stat:IsA("NumberValue") or stat:IsA("StringValue") then
						order = order + 1
						local val = stat.Value
						local display = (type(val) == "number") and formatNumber(val) or tostring(val)
						createStatEntry(stat.Name, display, order)

						-- Live update
						local conn = stat.Changed:Connect(function(newVal)
							if statLabels[stat.Name] then
								local d = (type(newVal) == "number") and formatNumber(newVal) or tostring(newVal)
								statLabels[stat.Name].Text = '<font weight="bold">' .. d .. '</font>'
							end
						end)
						table.insert(connections, conn)
					end
				end

				if order == 0 then
					local noStats = Instance.new("TextLabel")
					noStats.Size = UDim2.new(1, 0, 0, 40)
					noStats.BackgroundTransparency = 1
					noStats.Text = "No leaderstats detected"

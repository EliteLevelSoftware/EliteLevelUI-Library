		-------------------------------------------------------------------------
		-- [WINDOW RESIZE SYSTEM] - Windows-style edge/corner drag resizing
		-------------------------------------------------------------------------
		do
			local resizeHandles = {}
			local resizing = false
			local resizeType = nil
			local resizeStart = nil
			local startSize = nil
			local startPos = nil

			-- Create invisible resize handle frames parented to the ScreenGui
			local function MakeResizeHandle(name, isCorner)
				local h = Instance.new("Frame")
				h.Name = "Resize_" .. name
				h.BackgroundTransparency = 1
				h.ZIndex = 200
				h.Parent = EliteUIInstance

				-- Hover highlight for feedback
				h.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseMovement then
						h.BackgroundTransparency = 0.85
						h.BackgroundColor3 = EliteUI.CurrentTheme and EliteUI.CurrentTheme.Foregrounds
							and EliteUI.CurrentTheme.Foregrounds.Medium or Color3.fromRGB(150, 150, 150)
					end
				end)
				h.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseMovement then
						h.BackgroundTransparency = 1
					end
				end)

				return h
			end

			-- Edge handles
			resizeHandles.right  = MakeResizeHandle("Right", false)
			resizeHandles.bottom = MakeResizeHandle("Bottom", false)
			resizeHandles.left   = MakeResizeHandle("Left", false)
			resizeHandles.top    = MakeResizeHandle("Top", false)
			-- Corner handles
			resizeHandles.br = MakeResizeHandle("BottomRight", true)
			resizeHandles.bl = MakeResizeHandle("BottomLeft", true)
			resizeHandles.tr = MakeResizeHandle("TopRight", true)
			resizeHandles.tl = MakeResizeHandle("TopLeft", true)

			-- Corner grip indicators on all 4 corners (diagonal dot pattern)
			do
				local cornerConfigs = {
					{ name = "BR", anchor = Vector2.new(1, 1), pos = UDim2.new(1, -3, 1, -3), dots = {
						{10, 10}, {6, 10}, {10, 6}, {2, 10}, {6, 6}, {10, 2},
					}},
					{ name = "BL", anchor = Vector2.new(0, 1), pos = UDim2.new(0, 3, 1, -3), dots = {
						{2, 10}, {6, 10}, {2, 6}, {10, 10}, {6, 6}, {2, 2},
					}},
					{ name = "TR", anchor = Vector2.new(1, 0), pos = UDim2.new(1, -3, 0, 3), dots = {
						{10, 2}, {6, 2}, {10, 6}, {2, 2}, {6, 6}, {10, 10},
					}},
					{ name = "TL", anchor = Vector2.new(0, 0), pos = UDim2.new(0, 3, 0, 3), dots = {
						{2, 2}, {6, 2}, {2, 6}, {10, 2}, {6, 6}, {2, 10},
					}},
				}

				for _, cfg in ipairs(cornerConfigs) do
					local gripContainer = Instance.new("Frame")
					gripContainer.Name = "Grip_" .. cfg.name
					gripContainer.Size = UDim2.fromOffset(12, 12)
					gripContainer.AnchorPoint = cfg.anchor
					gripContainer.Position = cfg.pos
					gripContainer.BackgroundTransparency = 1
					gripContainer.ZIndex = 201
					gripContainer.Parent = mainWindow

					for _, dp in ipairs(cfg.dots) do
						local dot = Instance.new("Frame")
						dot.Size = UDim2.fromOffset(2, 2)
						dot.Position = UDim2.fromOffset(dp[1] - 2, dp[2] - 2)
						dot.BackgroundColor3 = Color3.fromRGB(120, 120, 140)
						dot.BackgroundTransparency = 0.4
						dot.BorderSizePixel = 0
						dot.ZIndex = 202
						dot.Parent = gripContainer

						local dotCorner = Instance.new("UICorner")
						dotCorner.CornerRadius = UDim.new(1, 0)
						dotCorner.Parent = dot

						ThemeMethods.bindTheme(dot, "BackgroundColor3", "Foregrounds.Dark")
					end
				end
			end

			local function updateResizeHandles()
				if not mainWindow.Visible then
					for _, h in pairs(resizeHandles) do h.Visible = false end
					return
				end
				for _, h in pairs(resizeHandles) do h.Visible = true end

				local pos = mainWindow.AbsolutePosition
				local sz = mainWindow.AbsoluteSize
				local HP = RESIZE_HANDLE_PX
				local CP = RESIZE_CORNER_PX

				resizeHandles.right.Size = UDim2.fromOffset(HP, sz.Y - CP * 2)
				resizeHandles.right.Position = UDim2.fromOffset(pos.X + sz.X, pos.Y + CP)

				resizeHandles.left.Size = UDim2.fromOffset(HP, sz.Y - CP * 2)
				resizeHandles.left.Position = UDim2.fromOffset(pos.X - HP, pos.Y + CP)

				resizeHandles.bottom.Size = UDim2.fromOffset(sz.X - CP * 2, HP)
				resizeHandles.bottom.Position = UDim2.fromOffset(pos.X + CP, pos.Y + sz.Y)

				resizeHandles.top.Size = UDim2.fromOffset(sz.X - CP * 2, HP)
				resizeHandles.top.Position = UDim2.fromOffset(pos.X + CP, pos.Y - HP)

				resizeHandles.br.Size = UDim2.fromOffset(CP, CP)
				resizeHandles.br.Position = UDim2.fromOffset(pos.X + sz.X - CP, pos.Y + sz.Y - CP)

				resizeHandles.bl.Size = UDim2.fromOffset(CP, CP)
				resizeHandles.bl.Position = UDim2.fromOffset(pos.X - HP, pos.Y + sz.Y - CP)

				resizeHandles.tr.Size = UDim2.fromOffset(CP, CP)
				resizeHandles.tr.Position = UDim2.fromOffset(pos.X + sz.X - CP, pos.Y - HP)

				resizeHandles.tl.Size = UDim2.fromOffset(CP, CP)
				resizeHandles.tl.Position = UDim2.fromOffset(pos.X - HP, pos.Y - HP)
			end

			-- Update handle positions only when window moves or resizes (not every frame)
			local function hookResizeHandleUpdates()
				local function onChanged(prop)
					if prop == "Position" or prop == "Size" or prop == "AbsolutePosition" or prop == "AbsoluteSize" then
						updateResizeHandles()
					end
				end
				table.insert(connections, mainWindow:GetPropertyChangedSignal("Position"):Connect(function() updateResizeHandles() end))
				table.insert(connections, mainWindow:GetPropertyChangedSignal("Size"):Connect(function() updateResizeHandles() end))
				updateResizeHandles() -- initial update
			end
			hookResizeHandleUpdates()

			-- Connect each handle to begin resize
			local function connectResizeHandle(handle, rType)
				handle.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1
					or input.UserInputType == Enum.UserInputType.Touch then
						resizing = true
						Resizing = true
						resizeType = rType
						resizeStart = input.Position
						startSize = Vector2.new(mainWindow.Size.X.Offset, mainWindow.Size.Y.Offset)
						startPos = Vector2.new(mainWindow.Position.X.Offset, mainWindow.Position.Y.Offset)
						input.Changed:Connect(function()
							if input.UserInputState == Enum.UserInputState.End then
								resizing = false
								Resizing = false
								resizeType = nil
								-- Update the drag bar position
								if EliteDrag then
									EliteDrag.Position = UDim2.new(
										0.5, 0, 0,
										mainWindow.Position.Y.Offset + mainWindow.Size.Y.Offset + 10
									)
								end
								-- Store for unmaximize
								EliteUI.Window.CurrentSize = mainWindow.Size
							end
						end)
					end
				end)
			end

			connectResizeHandle(resizeHandles.right, "right")
			connectResizeHandle(resizeHandles.bottom, "bottom")
			connectResizeHandle(resizeHandles.left, "left")
			connectResizeHandle(resizeHandles.top, "top")
			connectResizeHandle(resizeHandles.br, "br")
			connectResizeHandle(resizeHandles.bl, "bl")
			connectResizeHandle(resizeHandles.tr, "tr")
			connectResizeHandle(resizeHandles.tl, "tl")

			-- Process resize movement
			table.insert(connections, UserInputService.InputChanged:Connect(function(input)
				if not resizing then return end
				if input.UserInputType ~= Enum.UserInputType.MouseMovement
				and input.UserInputType ~= Enum.UserInputType.Touch then return end

				local delta = input.Position - resizeStart
				local newW = startSize.X
				local newH = startSize.Y
				local newX = startPos.X
				local newY = startPos.Y
				local rt = resizeType

				-- Right edge
				if rt == "right" or rt == "br" or rt == "tr" then
					newW = math.max(RESIZE_MIN_W, startSize.X + delta.X)
				end
				-- Bottom edge
				if rt == "bottom" or rt == "br" or rt == "bl" then
					newH = math.max(RESIZE_MIN_H, startSize.Y + delta.Y)
				end
				-- Left edge
				if rt == "left" or rt == "bl" or rt == "tl" then
					local proposed = startSize.X - delta.X
					if proposed >= RESIZE_MIN_W then
						newW = proposed
						newX = startPos.X + delta.X
					else
						newW = RESIZE_MIN_W
						newX = startPos.X + (startSize.X - RESIZE_MIN_W)
					end
				end
				-- Top edge
				if rt == "top" or rt == "tr" or rt == "tl" then
					local proposed = startSize.Y - delta.Y
					if proposed >= RESIZE_MIN_H then
						newH = proposed
						newY = startPos.Y + delta.Y
					else
						newH = RESIZE_MIN_H
						newY = startPos.Y + (startSize.Y - RESIZE_MIN_H)
					end
				end

				newW = math.floor(newW)
				newH = math.floor(newH)
				newX = math.floor(newX)
				newY = math.floor(newY)

				mainWindow.Size = UDim2.fromOffset(newW, newH)
				mainWindow.Position = UDim2.fromOffset(newX, newY)

				-- Keep drag bar in sync
				if EliteDrag then
					EliteDrag.Position = UDim2.new(
						0.5, 0, 0, newY + newH + 10
					)
				end
			end))

			-- Cleanup handles on destroy
			EliteUIInstance.Destroying:Connect(function()
				for _, h in pairs(resizeHandles) do
					pcall(function() h:Destroy() end)
				end
			end)
		end
		-------------------------------------------------------------------------
		-- [END WINDOW RESIZE SYSTEM]
		-------------------------------------------------------------------------

		--if not WindowSettings.LoadingEnabled then task.wait(.15) end
	end


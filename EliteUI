						for _, sw in ipairs(EliteUI.SubWindows) do
							pcall(function() sw.Enabled = false end)
						end
						task.delay(0.4, function()
							debounce = false
						end)
					end
				end
			end
		end)
	end

	-- Hook window state persistence (auto-save on move/resize/theme change)
	-- and load any saved state (position, size, theme, transparency)
	-- Hook window state persistence (auto-save on move/resize/theme change)
	task.spawn(function()
		-- Wait for loading animation to finish and window to settle
		local waitTime = WindowSettings.LoadingEnabled and 6 or 0.5
		task.wait(waitTime)
		EliteUI:_hookWindowStateListeners()

					Tween(
						dragBarCosmetic,
						{ Size = UDim2.new(0, 110, 0, 4), BackgroundTransparency = 0 },
						nil,
						TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
					)

function EliteUI:SetTheme(newTheme)
	local themeToCopy = newTheme
	if type(themeToCopy) == "string" then
		EliteUI._currentThemeName = newTheme
		themeToCopy = EliteUI.Themes[themeToCopy]
	else
		-- Reverse lookup name
		for name, theme in pairs(EliteUI.Themes) do
			if theme == newTheme then
				EliteUI._currentThemeName = name
				break
			end
		end
	end

	EliteUI.CurrentTheme = deepCopy(themeToCopy)
	themeEvent:Fire()
	-- Apply theme transparency
	pcall(function() transparencyEvent:Fire() end)
end

-- Set transparency independent of theme (0-1, nil to reset to theme default)
function EliteUI:SetTransparency(alpha)
	if alpha == nil then
		transparencyOverride = nil
	else
		transparencyOverride = math.clamp(alpha, 0, 1)
	end
	pcall(function() transparencyEvent:Fire() end)
end

function EliteUI:LoadAutoloadTheme()
	if isStudio or not isfile then
		return "Config system unavailable."
	end

	if EliteUI.FileSystem.AutoloadThemePath and isfile(EliteUI.FileSystem.AutoloadThemePath .. "autoload.txt") then
		local name = readfile(EliteUI.FileSystem.AutoloadThemePath .. "autoload.txt")

		if Themes[name] then
			EliteUI:SetTheme(name)
		else
			local content =
				readfile(EliteUI.FileSystem.AutoloadThemePath .. name .. EliteUI.FileSystem.FileExtension)
			local success, decoded = pcall(HttpService.JSONDecode, HttpService, content)
			if not success then
				return false, "Unable to decode JSON data."
			end

			EliteUI:SetTheme(decoded)
		end
	end
end

-- ============================================================
-- WINDOW STATE PERSISTENCE (per-game save/restore)
-- ============================================================
do
	local stateFolder = "ELS_WindowState"
	local stateFile = stateFolder .. "/place_" .. tostring(game.PlaceId) .. ".json"
	local stateSaveDebounce = false
	local stateLoaded = false
	local stateHooked = false

	local function ensureStateFolder()
		pcall(function()
			if isfolder and makefolder then
				if not isfolder(stateFolder) then
					makefolder(stateFolder)
				end
			end
		end)
	end

	-- Read saved state from disk without applying (for early use in CreateWindow)
	function EliteUI:_readSavedState()
		if isStudio then return nil end
		if not isfile or not readfile then return nil end
		local ok, state = pcall(function()
			if isfile(stateFile) then
				return HttpService:JSONDecode(readfile(stateFile))
			end
			return nil
		end)
		if ok and state then return state end
		return nil
	end

	-- Save current window state
	function EliteUI:SaveWindowState()
		if isStudio then return end
		if not writefile then return end
		if stateSaveDebounce then return end

		local mainWin = EliteUI.Window and EliteUI.Window.Instance
		if not mainWin then return end

		stateSaveDebounce = true

		local ok, err = pcall(function()
			ensureStateFolder()

			local currentThemeName = EliteUI._currentThemeName
			if not currentThemeName then
				-- Fallback: reverse lookup by color
				for name, theme in pairs(Themes) do
					if EliteUI.CurrentTheme and EliteUI.CurrentTheme.Backgrounds
						and theme.Backgrounds and theme.Backgrounds.Dark == EliteUI.CurrentTheme.Backgrounds.Dark
						and theme.Backgrounds.Medium == EliteUI.CurrentTheme.Backgrounds.Medium then
						currentThemeName = name
						break
					end
				end
			end

			local state = {
				PosX = math.floor(mainWin.Position.X.Offset),
				PosY = math.floor(mainWin.Position.Y.Offset),
				SizeW = math.floor(mainWin.Size.X.Offset),
				SizeH = math.floor(mainWin.Size.Y.Offset),
				Theme = currentThemeName,
				Transparency = transparencyOverride,
			}

			writefile(stateFile, HttpService:JSONEncode(state))
		end)

		if not ok then
			warn("[EliteUI] SaveWindowState error: " .. tostring(err))
		end

		task.delay(1, function()
			stateSaveDebounce = false
		end)
	end

	-- Load and apply saved window state
	function EliteUI:LoadWindowState()
		if isStudio then return nil end
		if not isfile or not readfile then return nil end
		if stateLoaded then return nil end

		local mainWin = EliteUI.Window and EliteUI.Window.Instance
		if not mainWin then
			warn("[EliteUI] LoadWindowState: No window instance found")
			return nil
		end

		local success, state = pcall(function()
			if isfile(stateFile) then
				local content = readfile(stateFile)
				return HttpService:JSONDecode(content)
			end
			return nil
		end)

		if not success or not state then return nil end
		stateLoaded = true

		-- Restore position and size
		pcall(function()
			if state.PosX and state.PosY then
				mainWin.Position = UDim2.fromOffset(state.PosX, state.PosY)
			end
			if state.SizeW and state.SizeH then
				local w = math.max(RESIZE_MIN_W, state.SizeW)
				local h = math.max(RESIZE_MIN_H, state.SizeH)
				mainWin.Size = UDim2.fromOffset(w, h)
				if EliteUI.Window then
					EliteUI.Window.CurrentSize = mainWin.Size
				end
			end
			-- Update drag bar position
			if EliteUIInstance and EliteUIInstance:FindFirstChild("Drag") then
				EliteDrag.Position = UDim2.new(
					0.5, 0, 0,
					mainWin.Position.Y.Offset + mainWin.Size.Y.Offset + 10
				)
			end
		end)

		-- Restore theme
		pcall(function()
			if state.Theme and Themes[state.Theme] then
				EliteUI:SetTheme(state.Theme)
			end
		end)

		-- Restore transparency
		pcall(function()
			if state.Transparency ~= nil then
				transparencyOverride = state.Transparency
			end
		end)

		return state
	end

	-- Hook auto-save listeners once the window exists
	function EliteUI:_hookWindowStateListeners()
		if stateHooked then return end
		local mainWin = EliteUI.Window and EliteUI.Window.Instance
		if not mainWin then
			warn("[EliteUI] _hookWindowStateListeners: No window instance")
			return
		end
		stateHooked = true

		-- Auto-save on window move/resize (event-driven, not polling)
		table.insert(connections, mainWin:GetPropertyChangedSignal("Position"):Connect(function()
			EliteUI:SaveWindowState()
		end))
		table.insert(connections, mainWin:GetPropertyChangedSignal("Size"):Connect(function()
			EliteUI:SaveWindowState()
		end))

		-- Auto-save when theme changes
		themeEvent.Event:Connect(function()
			task.delay(0.5, function()
				EliteUI:SaveWindowState()
			end)
		end)
	end
end


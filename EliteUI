										if i.UserInputType ~= Enum.UserInputType.MouseButton1 then
											return
										end
										local p, pos, size =
											i.Position,
											NestedElement.Instances[2].AbsolutePosition,
											NestedElement.Instances[2].AbsoluteSize
										if
											not (
												p.X >= pos.X
													and p.X <= pos.X + size.X
													and p.Y >= pos.Y
													and p.Y <= pos.Y + size.Y
											) and not hover

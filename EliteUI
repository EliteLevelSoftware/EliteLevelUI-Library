        -- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
        -- Generic reusable tile grid widget. Works in any tab, any game.
        --
        -- config = {
        --   CellWidth     = number,   px width of each tile (default 120)
        --   CellHeight    = number,   px height of each tile (default 130)
        --   Padding       = number,   grid padding in px (default 8)
        --   Section       = string,   optional header label above grid
        --   SelectLabel   = string,   info bar text when nothing is selected
        --   MultiSelect   = bool,     allow multiple tiles selected simultaneously
        --   ActionButtons = {         buttons shown in bottom bar
        --     { Name=string, Callback=function(selectedItem, allSelected) }
        --   },
        --   ActionToggles = {         toggle switches shown in bottom bar
        --     { Name=string, NameOn=string, CurrentValue=bool,
        --       Callback=function(isOn, selectedItem, allSelected) }
        --   },
        -- }
        --
        -- items = array of {
        --   Title    = string,        tile label
        --   Subtitle = string,        tile sublabel (optional)
        --   Model    = Instance,      Model instance for 3D ViewportFrame (optional)
        --   InfoText = string,        info bar text when this tile is selected (optional)
        --   Callback = function(item) fires on click, after selection state updates
        -- }
        --
        -- Returns: Grid object {
        --   SelectedItem  = item|nil       single-select: currently selected item
        --   SelectedItems = {item,...}     all selected items (MultiSelect mode)
        --   Refresh(newItems)              replace all tiles with new items
        --   Destroy()                      remove the grid
        -- }
        function TabWrapper:CreateTileGrid(items, config)
            config = config or {}
            local cellW         = config.CellWidth    or 120
            local cellH         = config.CellHeight   or 130
            local padding       = config.Padding      or 8
            local multiSelect   = config.MultiSelect  or false
            -- Unified Actions array тАФ mix buttons and toggles in any order
            -- Each action: { Type="Button"|"Toggle", Name=string, NameOn=string, CurrentValue=bool, Callback=fn }
            -- Legacy ActionButtons still supported for backwards compat
            local actions = config.Actions or {}
            for _, b in ipairs(config.ActionButtons or {}) do
                table.insert(actions, { Type="Button", Name=b.Name, Callback=b.Callback })
            end
            local selectLabel = config.SelectLabel or "Nothing selected"
            local hasBar   = #actions > 0
            local infoBarH = hasBar and 32 or 0
            local btnBarH  = hasBar and 44 or 0
            local barH     = infoBarH + btnBarH

            -- Wait for Column_1 in the real tab page
            -- Column_1 is created by CreateTab via task.spawn so we need to wait for it
            local column = nil
            local waited = 0
            repeat
                task.wait(0.1); waited += 0.1
                column = realPage:FindFirstChild("Column_1")
            until column ~= nil or waited > 5

            if not column then
                warn("[EliteUI] CreateTileGrid: Column_1 not found after 5s тАФ tab may not have been created correctly")
                return nil
            end

            -- Clear column layout so we can fill it freely
            for _, v in ipairs(column:GetChildren()) do
                if v:IsA("UIListLayout") or v:IsA("UIPadding") then v:Destroy() end
            end
            pcall(function() column.ScrollingEnabled = false end)
            pcall(function() column.CanvasSize = UDim2.fromOffset(0,0) end)

            -- Scrolling tile grid
            local scrollFrame = Instance.new("ScrollingFrame")
            scrollFrame.Size = UDim2.new(1, 0, 1, -barH)
            scrollFrame.Position = UDim2.fromOffset(0, 0)
            scrollFrame.BackgroundTransparency = 1
            scrollFrame.BorderSizePixel = 0
            scrollFrame.ScrollBarThickness = 4
            scrollFrame.ScrollingDirection = Enum.ScrollingDirection.Y
            scrollFrame.CanvasSize = UDim2.fromOffset(0, 0)
            scrollFrame.ZIndex = 2
            scrollFrame.Parent = column
            ThemeMethods.bindTheme(scrollFrame, "ScrollBarImageColor3", "Foregrounds.Medium")

            local gridLayout = Instance.new("UIGridLayout")
            gridLayout.CellSize    = UDim2.fromOffset(cellW, cellH)
            gridLayout.CellPadding = UDim2.fromOffset(padding, padding)
            gridLayout.SortOrder   = Enum.SortOrder.LayoutOrder
            gridLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
            gridLayout.Parent = scrollFrame

            local gPad = Instance.new("UIPadding")
            gPad.PaddingTop=UDim.new(0,padding); gPad.PaddingLeft=UDim.new(0,padding)
            gPad.PaddingRight=UDim.new(0,padding); gPad.PaddingBottom=UDim.new(0,padding)
            gPad.Parent = scrollFrame

            gridLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                scrollFrame.CanvasSize = UDim2.fromOffset(0, gridLayout.AbsoluteContentSize.Y + padding*2)
            end)

            -- Grid state тАФ declared before action bar so callbacks close over it correctly
            local Grid = {}
            Grid.SelectedItem  = nil
            Grid.SelectedItems = {}

            -- Action bar
            local infoLabel = nil

            if barH > 0 then
                local sep = Instance.new("Frame")
                sep.Size=UDim2.new(1,0,0,1); sep.Position=UDim2.new(0,0,1,-barH)
                sep.BackgroundTransparency=0.5; sep.BorderSizePixel=0; sep.ZIndex=4
                sep.Parent=column
                ThemeMethods.bindTheme(sep,"BackgroundColor3","Foregrounds.Dark")

                -- Info row
                local infoRow = Instance.new("Frame")
                infoRow.Size=UDim2.new(1,0,0,infoBarH); infoRow.Position=UDim2.new(0,0,1,-barH)
                infoRow.BackgroundTransparency=1; infoRow.BorderSizePixel=0; infoRow.ZIndex=4
                infoRow.Parent=column

                infoLabel = Instance.new("TextLabel")
                infoLabel.Size=UDim2.new(1, -8, 1, 0)
                infoLabel.Position=UDim2.fromOffset(10,0)
                infoLabel.BackgroundTransparency=1; infoLabel.Text=selectLabel
                infoLabel.TextSize=12; infoLabel.Font=Enum.Font.GothamBold
                infoLabel.TextXAlignment=Enum.TextXAlignment.Left
                infoLabel.TextTruncate=Enum.TextTruncate.AtEnd; infoLabel.ZIndex=5
                infoLabel.Parent=infoRow
                ThemeMethods.bindTheme(infoLabel,"TextColor3","Foregrounds.Active")

                -- Button row
                local btnRow = Instance.new("Frame")
                btnRow.Size=UDim2.new(1,0,0,btnBarH); btnRow.Position=UDim2.new(0,0,1,-btnBarH)
                btnRow.BackgroundTransparency=1; btnRow.BorderSizePixel=0; btnRow.ZIndex=4
                btnRow.Parent=column

                local btnPad = Instance.new("UIPadding")
                btnPad.PaddingLeft=UDim.new(0,8); btnPad.PaddingRight=UDim.new(0,8)
                btnPad.PaddingTop=UDim.new(0,6); btnPad.PaddingBottom=UDim.new(0,6)
                btnPad.Parent=btnRow

                local btnList = Instance.new("UIListLayout")
                btnList.FillDirection=Enum.FillDirection.Horizontal
                btnList.SortOrder=Enum.SortOrder.LayoutOrder
                btnList.Padding=UDim.new(0,8)
                btnList.Parent=btnRow

                local totalActions = #actions

                -- Render each action in assigned order тАФ Button or Toggle
                for i, action in ipairs(actions) do
                    local isToggle = (action.Type == "Toggle")
                    local togValue = isToggle and (action.CurrentValue or false) or nil

                    local btn = Instance.new("TextButton")
                    btn.Size=UDim2.new(1/totalActions,-4,1,0); btn.LayoutOrder=i
                    btn.BorderSizePixel=0; btn.Text=action.Name or (isToggle and "Toggle" or "Action")
                    btn.TextSize=13; btn.Font=Enum.Font.GothamBold
                    btn.AutoButtonColor=false; btn.ZIndex=5; btn.Parent=btnRow
                    ThemeMethods.bindTheme(btn,"BackgroundColor3","Backgrounds.Groupbox")
                    ThemeMethods.bindTheme(btn,"TextColor3","Foregrounds.Light")
                    local bc=Instance.new("UICorner"); bc.CornerRadius=UDim.new(0,8); bc.Parent=btn
                    local bs=Instance.new("UIStroke"); bs.Thickness=1; bs.Parent=btn
                    ThemeMethods.bindTheme(bs,"Color","Foregrounds.Dark")

                    if isToggle then
                        local function applyTogState(v)
                            if v then
                                Tween(btn,{BackgroundColor3=EliteUI.CurrentTheme.Foregrounds.Active})
                                ThemeMethods.bindTheme(btn,"TextColor3","Backgrounds.Dark")
                                btn.Text = action.NameOn or action.Name or "Toggle"
                            else
                                Tween(btn,{BackgroundColor3=EliteUI.CurrentTheme.Backgrounds.Groupbox})
                                ThemeMethods.bindTheme(btn,"TextColor3","Foregrounds.Light")
                                btn.Text = action.Name or "Toggle"
                            end
                        end
                        applyTogState(togValue)
                        btn.MouseEnter:Connect(function()
                            if not togValue then
                                Tween(btn,{BackgroundColor3=EliteUI.CurrentTheme.Backgrounds.Highlight})
                            end
                        end)
                        btn.MouseLeave:Connect(function() applyTogState(togValue) end)
                        btn.MouseButton1Click:Connect(function()
                            togValue = not togValue
                            applyTogState(togValue)
                            if action.Callback then
                                pcall(action.Callback, togValue, Grid.SelectedItem, Grid.SelectedItems)
                            end
                        end)
                    else
                        btn.MouseEnter:Connect(function()
                            Tween(btn,{BackgroundColor3=EliteUI.CurrentTheme.Backgrounds.Highlight})
                        end)
                        btn.MouseLeave:Connect(function()
                            Tween(btn,{BackgroundColor3=EliteUI.CurrentTheme.Backgrounds.Groupbox})
                        end)
                        btn.MouseButton1Click:Connect(function()
                            if action.Callback then
                                pcall(action.Callback, Grid.SelectedItem, Grid.SelectedItems)
                            end
                        end)
                    end
                end

            end

            -- Selection state
            local selectedTiles  = {} -- frame -> item, for MultiSelect
            local selectedTile   = nil
            local selectedStroke = nil

            local function updateInfoLabel(item)
                if not infoLabel then return end
                if item and item.InfoText then
                    infoLabel.Text = item.InfoText
                elseif item then
                    local parts = {}
                    if item.Title    then table.insert(parts, item.Title) end
                    if item.Subtitle then table.insert(parts, item.Subtitle) end
                    infoLabel.Text = #parts > 0 and table.concat(parts, "  |  ") or selectLabel
                else
                    infoLabel.Text = selectLabel
                end
            end

            local function deselectAll()
                for tile, _ in pairs(selectedTiles) do
                    pcall(function()
                        local stroke = tile:FindFirstChildOfClass("UIStroke")
                        Tween(tile,   {BackgroundColor3=EliteUI.CurrentTheme.Backgrounds.Groupbox})
                        if stroke then Tween(stroke,{Color=EliteUI.CurrentTheme.Foregrounds.Dark,Thickness=1}) end
                    end)
                end
                selectedTiles  = {}
                selectedTile   = nil
                selectedStroke = nil
                Grid.SelectedItem  = nil
                Grid.SelectedItems = {}
                updateInfoLabel(nil)
            end

            local tileFrames = {}

            local function buildTile(item, order)
                local tile = Instance.new("TextButton")
                tile.Size=UDim2.fromOffset(cellW,cellH); tile.LayoutOrder=order
                tile.Text=""; tile.AutoButtonColor=false; tile.BorderSizePixel=0
                tile.ClipsDescendants=true; tile.ZIndex=3; tile.Parent=scrollFrame
                ThemeMethods.bindTheme(tile,"BackgroundColor3","Backgrounds.Groupbox")

                local tileCorner=Instance.new("UICorner"); tileCorner.CornerRadius=UDim.new(0,8); tileCorner.Parent=tile
                local tileStroke=Instance.new("UIStroke"); tileStroke.Thickness=1; tileStroke.Parent=tile
                ThemeMethods.bindTheme(tileStroke,"Color","Foregrounds.Dark")

                -- ViewportFrame for 3D model
                local vpH = cellH - 42
                local vpFrame = Instance.new("ViewportFrame")
                vpFrame.Size=UDim2.new(1,0,0,vpH); vpFrame.BackgroundTransparency=1
                vpFrame.BorderSizePixel=0; vpFrame.LightColor=Color3.fromRGB(255,235,200)
                vpFrame.LightDirection=Vector3.new(-1,-2,-1); vpFrame.ZIndex=4; vpFrame.Parent=tile

                if item.Model then
                    task.spawn(function()
                        task.wait(order * 0.04)
                        local modelInst = nil
                        if typeof(item.Model)=="Instance" then
                            modelInst = item.Model
                        elseif type(item.Model)=="string" then
                            pcall(function()
                                local ref=game
                                for _,p in ipairs(item.Model:split(".")) do ref=ref:FindFirstChild(p) or ref[p] end
                                modelInst=ref
                            end)
                        end
                        if not modelInst then return end
                        local ok,clone=pcall(function() return modelInst:Clone() end)
                        if not ok or not clone then return end
                        for _,v in ipairs(clone:GetDescendants()) do
                            if v:IsA("Script") or v:IsA("LocalScript") or v:IsA("ModuleScript")
                            or v:IsA("ProximityPrompt") or v:IsA("ClickDetector")
                            or v:IsA("Sound") or v:IsA("ParticleEmitter") then
                                pcall(function()v:Destroy()end)
                            end
                        end
                        clone.Parent=vpFrame
                        local cam=Instance.new("Camera"); cam.FieldOfView=45
                        local ok2,cf,size=pcall(function() return clone:GetBoundingBox() end)
                        if ok2 and cf then
                            local dist=math.max(size.X,size.Y,size.Z)*2.2
                            cam.CFrame=CFrame.new(cf.Position+Vector3.new(dist*.45,size.Y*.35,dist*.75),cf.Position)
                        end
                        cam.Parent=vpFrame; vpFrame.CurrentCamera=cam
                    end)
                end

                local titleLbl=Instance.new("TextLabel")
                titleLbl.Size=UDim2.new(1,-6,0,16); titleLbl.Position=UDim2.new(0,3,1,-38)
                titleLbl.BackgroundTransparency=1; titleLbl.Text=item.Title or ""
                titleLbl.TextSize=10; titleLbl.Font=Enum.Font.GothamBold
                titleLbl.TextXAlignment=Enum.TextXAlignment.Center
                titleLbl.TextTruncate=Enum.TextTruncate.AtEnd; titleLbl.ZIndex=5; titleLbl.Parent=tile
                ThemeMethods.bindTheme(titleLbl,"TextColor3","Foregrounds.Light")

                local subLbl=Instance.new("TextLabel")
                subLbl.Size=UDim2.new(1,-6,0,14); subLbl.Position=UDim2.new(0,3,1,-22)
                subLbl.BackgroundTransparency=1; subLbl.Text=item.Subtitle or ""
                subLbl.TextSize=9; subLbl.Font=Enum.Font.Gotham
                subLbl.TextXAlignment=Enum.TextXAlignment.Center
                subLbl.TextTruncate=Enum.TextTruncate.AtEnd; subLbl.ZIndex=5; subLbl.Parent=tile
                ThemeMethods.bindTheme(subLbl,"TextColor3","Foregrounds.Medium")

                tile.MouseEnter:Connect(function()
                    if not selectedTiles[tile] then
                        Tween(tile,{BackgroundColor3=EliteUI.CurrentTheme.Backgrounds.Highlight})
                        Tween(tileStroke,{Color=EliteUI.CurrentTheme.Foregrounds.Medium})
                    end
                end)
                tile.MouseLeave:Connect(function()
                    if not selectedTiles[tile] then
                        Tween(tile,{BackgroundColor3=EliteUI.CurrentTheme.Backgrounds.Groupbox})
                        Tween(tileStroke,{Color=EliteUI.CurrentTheme.Foregrounds.Dark})
                    end
                end)

                tile.MouseButton1Click:Connect(function()
                    if not multiSelect then
                        deselectAll()
                    elseif selectedTiles[tile] then
                        -- Deselect this tile in multi-select
                        selectedTiles[tile] = nil
                        Tween(tile,{BackgroundColor3=EliteUI.CurrentTheme.Backgrounds.Groupbox})
                        Tween(tileStroke,{Color=EliteUI.CurrentTheme.Foregrounds.Dark,Thickness=1})
                        -- Rebuild SelectedItems
                        Grid.SelectedItems = {}
                        for _, it in pairs(selectedTiles) do table.insert(Grid.SelectedItems, it) end
                        Grid.SelectedItem = Grid.SelectedItems[1] or nil
                        updateInfoLabel(Grid.SelectedItem)
                        if item.Callback then pcall(item.Callback, item) end
                        return
                    end

                    -- Select this tile
                    selectedTiles[tile] = item
                    selectedTile        = tile
                    selectedStroke      = tileStroke
                    Grid.SelectedItem   = item
                    Grid.SelectedItems  = {}
                    for _, it in pairs(selectedTiles) do table.insert(Grid.SelectedItems, it) end

                    Tween(tile,{BackgroundColor3=EliteUI.CurrentTheme.Backgrounds.Highlight})
                    Tween(tileStroke,{Color=EliteUI.CurrentTheme.Foregrounds.Active,Thickness=2})
                    updateInfoLabel(item)
                    if item.Callback then pcall(item.Callback, item) end
                end)

                return tile
            end

            for i, item in ipairs(items or {}) do
                tileFrames[i] = buildTile(item, i)
            end

            function Grid:Refresh(newItems)
                deselectAll()
                for _,f in ipairs(tileFrames) do pcall(function()f:Destroy()end) end
                tileFrames={}
                for i,item in ipairs(newItems or {}) do tileFrames[i]=buildTile(item,i) end
            end

            function Grid:Destroy()
                pcall(function()scrollFrame:Destroy()end)
            end

            return Grid
        end
        return TabWrapper
    end

    function SubWindowWrapper:Destroy()
        pcall(function() subInst:Destroy() end)
    end

    return SubWindowWrapper
end

return Rayfield

        KeySystem = Settings.KeySystem or { Enabled = false },
        Discord = Settings.Discord or { Enabled = false },
    }

    -- Map Rayfield ConfigurationSaving to EliteUI FileSettings
    if Settings.ConfigurationSaving and Settings.ConfigurationSaving.Enabled then
        eliteSettings.FileSettings = {
            ConfigFolder = Settings.ConfigurationSaving.FileName or "EliteConfig",
        }
    end
    -- When ConfigurationSaving is disabled or missing, don't pass FileSettings
    -- This avoids BuildFolderTree trying to create folders with nil paths

    -- Apply theme if provided
    if Settings.Theme then
        if type(Settings.Theme) == "string" then
            pcall(function()
                EliteUI:SetTheme(Settings.Theme)
            end)
        elseif type(Settings.Theme) == "table" then
            -- Rayfield custom theme table - try to map it
            -- Rayfield themes use flat Color3 values, EliteUI uses nested structure
            -- For now, just try direct set
            pcall(function()
                EliteUI:SetTheme(Settings.Theme)
            end)
        end
    end

    -- Create the actual window
    EliteUI:CreateWindow(eliteSettings)

    -- Create a default tab section for Rayfield-style flat tab creation
    local defaultSection = EliteUI.Window:CreateTabSection()

    -- Build the Window wrapper with Rayfield-compatible methods
    local WindowWrapper = {}
    WindowWrapper._section = defaultSection
    WindowWrapper._sectionCount = 0
    WindowWrapper._sections = { [""] = defaultSection }

    -- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
    -- Window:CreateTab(Name, Icon)
    -- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
    -- Rayfield: Window:CreateTab("Tab Name", "icon-id")
    -- EliteUI: TabSection:CreateTab({Name, Columns, Icon}, TabIndex)
    -- Icons are now handled natively by EliteUI's setIcon() function
    -- which loads Rayfield's Lucide icon library at startup.

    function WindowWrapper:CreateTab(Name, Icon, Settings)
        -- Support both Rayfield styles:
        -- CreateTab("Name", "icon") and CreateTab({Name = "Name", Icon = "icon"})
        local tabName, tabIcon, tabColumns

        if type(Name) == "table" then
            tabName = Name.Name or "Tab"
            tabIcon = Name.Icon or ""
            tabColumns = Name.Columns or 1
        else
            tabName = Name or "Tab"
            tabIcon = Icon or ""
            tabColumns = (Settings and Settings.Columns) or 1
        end

        local tabIndex = nextIndex("tab")

        local nativeTab = defaultSection:CreateTab({
            Name = tabName,
            Columns = tabColumns,
            Icon = tabIcon,
        }, tabIndex)

        -- Build the Tab wrapper with Rayfield-compatible methods
        local TabWrapper = {}
        TabWrapper._native = nativeTab
        TabWrapper._autoGroupbox = nil
        TabWrapper._currentSection = nil

        -- Auto-create a default groupbox for elements added without a section
        local function ensureGroupbox()
            if TabWrapper._autoGroupbox == nil then
                TabWrapper._autoGroupbox = nativeTab:CreateGroupbox({
                    Name = "",
                    Column = 1,
                    Style = 2,
                }, nextIndex("grp"))
            end
            return TabWrapper._autoGroupbox
        end

        -- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
        -- Rayfield-compatible :Set() wrappers
        -- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
        -- Rayfield uses raw values: Toggle:Set(false), Slider:Set(10)
        -- EliteUI native uses tables: Toggle:Set({CurrentValue = false})
        -- These wrappers accept BOTH formats for full compatibility.
        -- Uses task.defer to wrap Set after native definition completes (no polling).

        local function deferWrapSet(element, converter)
            if not element then return element end
            task.defer(function()
                -- task.defer runs after the current resumption cycle, giving
                -- native task.spawn inside CreateToggle/CreateSlider/etc time to define Set
                if not element.Set then
                    -- One extra yield if still not ready
                    task.wait(0.1)
                end
                if not element.Set then return end
                local nativeSet = element.Set
                element.Set = function(self, value)
                    return nativeSet(self, converter(value))
                end
            end)
            return element
        end

        local function wrapToggleSet(element)
            if not element then return element end
            deferWrapSet(element, function(value)
                if type(value) == "boolean" then return {CurrentValue = value} end
                return value
            end)
            task.defer(function()
                if element and element.Values then element.CurrentValue = element.Values.CurrentValue end
            end)
            return element
        end

        local function wrapSliderSet(element)
            if not element then return element end
            deferWrapSet(element, function(value)
                if type(value) == "number" then return {CurrentValue = value} end
                return value
            end)
            task.defer(function()
                if element and element.Values then element.CurrentValue = element.Values.CurrentValue end
            end)
            return element
        end

        local function wrapDropdownSet(element)
            if not element then return element end
            deferWrapSet(element, function(value)
                if type(value) == "table" and value.CurrentOption then return value end
                if type(value) == "table" and #value > 0 and type(value[1]) == "string" then
                    return {CurrentOption = value}
                end
                return value
            end)
            task.defer(function()
                if element and element.Values then element.CurrentOption = element.Values.CurrentOption end
            end)
            return element
        end

        local function wrapButtonSet(element)
            if not element then return element end
            deferWrapSet(element, function(value)
                if type(value) == "string" then return {Name = value} end
                return value
            end)
            return element
        end

        local function wrapInputSet(element)
            if not element then return element end
            deferWrapSet(element, function(value)
                if type(value) == "string" then return {CurrentValue = value} end
                return value
            end)
            task.defer(function()
                if element and element.Values then element.CurrentValue = element.Values.CurrentValue end
            end)
            return element
        end

        local function wrapLabelSet(element)
            if not element then return element end
            deferWrapSet(element, function(value)
                if type(value) == "string" then return {Name = value} end
                return value
            end)
            return element
        end

        -- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
        -- Tab:CreateSection(Name)
        -- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
        -- Rayfield: Tab:CreateSection("Section Name")
        -- EliteUI: Tab:CreateGroupbox({Name, Column, Style}, Index)
        -- In Rayfield, CreateSection returns the section object which has element creation methods.
        -- Elements are added to the LAST created section.

        function TabWrapper:CreateSection(SectionName, Column)
            local groupbox = nativeTab:CreateGroupbox({
                Name = SectionName or "",
                Column = Column or 1,
                Style = 1,
            }, nextIndex("sec"))

            TabWrapper._currentSection = groupbox

            -- Build a Section wrapper
            local SectionWrapper = {}
            SectionWrapper._native = groupbox

            -- Forward all element creation to this groupbox with Rayfield-compat Set()
            local wrapSetMap = {
                Button = wrapButtonSet, Toggle = wrapToggleSet,
                Slider = wrapSliderSet, Input = wrapInputSet,
                Label = wrapLabelSet, Paragraph = wrapLabelSet,
            }
            local function wrapElement(methodName)
                SectionWrapper["Create" .. methodName] = function(self, ElementSettings, FlagOrIndex)
                    local idx = FlagOrIndex or nextIndex(methodName:lower())
                    local el = groupbox["Create" .. methodName](groupbox, ElementSettings, idx)
                    local wrapper = wrapSetMap[methodName]
                    return wrapper and wrapper(el) or el
                end
            end

            wrapElement("Button")
            wrapElement("Toggle")
            wrapElement("Slider")
            wrapElement("Input")
            wrapElement("Label")
            wrapElement("Paragraph")

            function SectionWrapper:CreateDivider()
                return groupbox:CreateDivider()
            end

            -- Dropdown in Rayfield is typically on a Label
            function SectionWrapper:CreateDropdown(ElementSettings, Flag)
                local idx = Flag or nextIndex("dropdown")
                -- In EliteUI, dropdowns are nested on labels
                local label = groupbox:CreateLabel({
                    Name = ElementSettings.Name or "Dropdown",
                }, nextIndex("lbl"))
                local dd = label:AddDropdown({
                    Options = ElementSettings.Options or {},
                    CurrentOption = ElementSettings.CurrentOption or ElementSettings.Default,
                    MultipleOptions = ElementSettings.MultipleOptions or ElementSettings.MultiSelect or false,
                    Placeholder = ElementSettings.Placeholder or nil,
                    Callback = ElementSettings.Callback or function() end,
                }, idx)
                -- Rayfield compat: :Refresh(newOptions, clearSelected)
                if dd and not dd.Refresh then
                    dd.Refresh = function(self, newOptions, clearSelected)
                        local opts = (type(self) == "table" and self ~= dd) and self or newOptions
                        local clear = (type(self) == "table" and self ~= dd) and newOptions or clearSelected
                        dd:Set({
                            Options = opts or dd.Values.Options,
                            CurrentOption = clear and {} or nil,
                        })
                    end
                end
                return wrapDropdownSet(dd)
            end

            -- Keybind in Rayfield
            function SectionWrapper:CreateKeybind(ElementSettings, Flag)
                local idx = Flag or nextIndex("bind")
                local label = groupbox:CreateLabel({
                    Name = ElementSettings.Name or "Keybind",
                }, nextIndex("lbl"))
                return label:AddBind({
                    CurrentValue = ElementSettings.CurrentKeybind or ElementSettings.CurrentValue or "",
                    HoldToInteract = ElementSettings.HoldToInteract or false,
                    Callback = ElementSettings.Callback or function() end,
                }, idx)
            end

            -- ColorPicker in Rayfield
            function SectionWrapper:CreateColorPicker(ElementSettings, Flag)
                local idx = Flag or nextIndex("cp")
                local label = groupbox:CreateLabel({
                    Name = ElementSettings.Name or "Color Picker",
                }, nextIndex("lbl"))
                return label:AddColorPicker({
                    CurrentValue = ElementSettings.Color or ElementSettings.CurrentValue or Color3.new(1,1,1),
                    Transparency = ElementSettings.Transparency or nil,
                    Callback = ElementSettings.Callback or function() end,
                }, idx)
            end

            return SectionWrapper
        end

        -- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
        -- Direct element creation on Tab (Rayfield style)
        -- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
        -- In Rayfield, you can create elements directly on a tab
        -- without explicitly creating a section first.
        -- We handle this by auto-creating a default groupbox.

        local function getActiveGroupbox()
            return TabWrapper._currentSection or ensureGroupbox()
        end

        function TabWrapper:CreateButton(ElementSettings, Flag)
            local gb = getActiveGroupbox()
            return wrapButtonSet(gb:CreateButton(ElementSettings, Flag or nextIndex("btn")))
        end

        function TabWrapper:CreateToggle(ElementSettings, Flag)
            local gb = getActiveGroupbox()
            return wrapToggleSet(gb:CreateToggle(ElementSettings, Flag or nextIndex("tgl")))
        end

        function TabWrapper:CreateSlider(ElementSettings, Flag)
            local gb = getActiveGroupbox()
            return wrapSliderSet(gb:CreateSlider(ElementSettings, Flag or nextIndex("sld")))
        end

        function TabWrapper:CreateInput(ElementSettings, Flag)
            local gb = getActiveGroupbox()
            return wrapInputSet(gb:CreateInput(ElementSettings, Flag or nextIndex("inp")))
        end

        function TabWrapper:CreateDropdown(ElementSettings, Flag)
            local gb = getActiveGroupbox()
            local idx = Flag or nextIndex("dropdown")
            local label = gb:CreateLabel({
                Name = ElementSettings.Name or "Dropdown",
            }, nextIndex("lbl"))
            local dd = label:AddDropdown({
                Options = ElementSettings.Options or {},
                CurrentOption = ElementSettings.CurrentOption or ElementSettings.Default,
                MultipleOptions = ElementSettings.MultipleOptions or ElementSettings.MultiSelect or false,
                Placeholder = ElementSettings.Placeholder or nil,
                Callback = ElementSettings.Callback or function() end,
            }, idx)
            -- Rayfield compat: :Refresh(newOptions, clearSelected)
            if dd and not dd.Refresh then
                dd.Refresh = function(self, newOptions, clearSelected)
                    local opts = (type(self) == "table" and self ~= dd) and self or newOptions
                    local clear = (type(self) == "table" and self ~= dd) and newOptions or clearSelected
                    dd:Set({
                        Options = opts or dd.Values.Options,
                        CurrentOption = clear and {} or nil,
                    })
                end
            end
            return wrapDropdownSet(dd)
        end

        function TabWrapper:CreateKeybind(ElementSettings, Flag)
            local gb = getActiveGroupbox()
            local idx = Flag or nextIndex("bind")
            local label = gb:CreateLabel({
                Name = ElementSettings.Name or "Keybind",
            }, nextIndex("lbl"))
            return label:AddBind({
                CurrentValue = ElementSettings.CurrentKeybind or ElementSettings.CurrentValue or "",
                HoldToInteract = ElementSettings.HoldToInteract or false,
                Callback = ElementSettings.Callback or function() end,
            }, idx)
        end

        function TabWrapper:CreateColorPicker(ElementSettings, Flag)
            local gb = getActiveGroupbox()
            local idx = Flag or nextIndex("cp")
            local label = gb:CreateLabel({
                Name = ElementSettings.Name or "Color Picker",
            }, nextIndex("lbl"))
            return label:AddColorPicker({
                CurrentValue = ElementSettings.Color or ElementSettings.CurrentValue or Color3.new(1,1,1),
                Transparency = ElementSettings.Transparency or nil,
                Callback = ElementSettings.Callback or function() end,
            }, idx)
        end

        function TabWrapper:CreateLabel(NameOrSettings, Flag)
            local gb = getActiveGroupbox()
            local settings
            if type(NameOrSettings) == "string" then
                settings = { Name = NameOrSettings }
            else
                settings = NameOrSettings
            end
            return wrapLabelSet(gb:CreateLabel(settings, Flag or nextIndex("lbl")))
        end

        function TabWrapper:CreateParagraph(ElementSettings, Flag)
            local gb = getActiveGroupbox()
            return gb:CreateParagraph(ElementSettings, Flag or nextIndex("para"))
        end

        function TabWrapper:CreateDivider()
            local gb = getActiveGroupbox()
            return gb:CreateDivider()
        end

        -- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
        -- Direct EliteUI access (for power users)
        -- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР

        function TabWrapper:CreateGroupbox(Settings, Index)
            return nativeTab:CreateGroupbox(Settings, Index or nextIndex("grp"))
        end

        function TabWrapper:BuildConfigGroupbox(Column, Style)
            return nativeTab:BuildConfigGroupbox(Column, Style)
        end

        function TabWrapper:BuildThemeGroupbox(Column, Style)
            return nativeTab:BuildThemeGroupbox(Column, Style)
        end

        -- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
        -- Tab:CreateTileGrid(items, config)
        -- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
        -- Creates a scrollable ViewportFrame grid inside the tab.
        -- Tiles auto-theme-bind to EliteUI.CurrentTheme.
        --
        -- config = {
        --     CellWidth  = number,   -- px, default 120
        --     CellHeight = number,   -- px, default 130
        --     Padding    = number,   -- px, default 8
        --     Section    = string,   -- groupbox header, optional
        --     Column     = number,   -- tab column, default 1
        -- }
        -- items = array of {
        --     Title    = string,
        --     Subtitle = string,           -- optional
        --     Model    = Instance|string,  -- Model instance or "workspace.Eggs.Basic" path
        --     Callback = function(),
        -- }
        -- Returns: { Refresh(newItems), Destroy() }

        function TabWrapper:CreateTileGrid(items, config)
            config = config or {}
            local cellW       = config.CellWidth  or 120
            local cellH       = config.CellHeight or 130
            local padding     = config.Padding    or 8
            local sectionName = config.Section    or ""

            -- Host groupbox
            local gb = nativeTab:CreateGroupbox({
                Name   = sectionName,
                Column = config.Column or 1,
                Style  = 1,
            }, nextIndex("tilegrid"))

            -- Wait for groupbox Instance to be ready, then grab PART_Backdrop
            -- PART_Backdrop has a real pixel size; PART_Content uses AutomaticSize.Y
            -- so scale-based sizing only works in PART_Backdrop.
            local backdrop = nil
            local waited = 0
            repeat
                task.wait(0.05)
                waited += 0.05
                if gb and gb.Instance then
                    backdrop = gb.Instance:FindFirstChild("PART_Backdrop")
                end
            until backdrop ~= nil or waited > 2

            if not backdrop then
                warn("[EliteUI] CreateTileGrid: groupbox backdrop not ready")
                return nil
            end

            -- Also grab ParentingItem to remove its list layout (prevents layout fights)
            local container = gb.ParentingItem
            if container then
                for _, v in ipairs(container:GetChildren()) do
                    if v:IsA("UIListLayout") or v:IsA("UIPadding") then v:Destroy() end
                end
            end

            -- Scrolling frame тАФ parented to PART_Backdrop so it fills real pixel space
            local scrollFrame = Instance.new("ScrollingFrame")
            scrollFrame.Size = UDim2.new(1, 0, 1, -barH)
            scrollFrame.Position = UDim2.fromOffset(0, 0)
            scrollFrame.BackgroundTransparency = 1
            scrollFrame.BorderSizePixel = 0
            scrollFrame.ScrollBarThickness = 4
            scrollFrame.ScrollingDirection = Enum.ScrollingDirection.Y
            scrollFrame.CanvasSize = UDim2.fromOffset(0, 0)
            scrollFrame.ZIndex = 2
            scrollFrame.Parent = backdrop
            ThemeMethods.bindTheme(scrollFrame, "ScrollBarImageColor3", "Foregrounds.Medium")

            local gridLayout = Instance.new("UIGridLayout")
            gridLayout.CellSize = UDim2.fromOffset(cellW, cellH)
            gridLayout.CellPadding = UDim2.fromOffset(padding, padding)
            gridLayout.SortOrder = Enum.SortOrder.LayoutOrder
            gridLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
            gridLayout.Parent = scrollFrame

            local gridPad = Instance.new("UIPadding")
            gridPad.PaddingTop    = UDim.new(0, padding)
            gridPad.PaddingLeft   = UDim.new(0, padding)
            gridPad.PaddingRight  = UDim.new(0, padding)
            gridPad.PaddingBottom = UDim.new(0, padding)
            gridPad.Parent = scrollFrame

            -- Keep canvas in sync with content
            gridLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                local contentH = gridLayout.AbsoluteContentSize.Y + padding * 2
                scrollFrame.CanvasSize = UDim2.fromOffset(0, contentH)
                local cap = math.min(contentH, (cellH + padding) * 3 + padding)
                scrollFrame.Size = UDim2.new(1, 0, 0, cap)
            end)

            local tileFrames = {}

            local function buildTile(item, order)
                local tile = Instance.new("TextButton")
                tile.Size = UDim2.fromOffset(cellW, cellH)
                tile.LayoutOrder = order
                tile.Text = ""
                tile.AutoButtonColor = false
                tile.BorderSizePixel = 0
                tile.ClipsDescendants = true
                tile.Parent = scrollFrame
                ThemeMethods.bindTheme(tile, "BackgroundColor3", "Backgrounds.Groupbox")

                local tileCorner = Instance.new("UICorner")
                tileCorner.CornerRadius = UDim.new(0, 8)
                tileCorner.Parent = tile

                local tileStroke = Instance.new("UIStroke")
                tileStroke.Thickness = 1
                tileStroke.Parent = tile
                ThemeMethods.bindTheme(tileStroke, "Color", "Foregrounds.Dark")

                -- ViewportFrame for 3D model preview
                local vpH = cellH - 46
                local vpFrame = Instance.new("ViewportFrame")
                vpFrame.Size = UDim2.new(1, 0, 0, vpH)
                vpFrame.BackgroundTransparency = 1
                vpFrame.BorderSizePixel = 0
                vpFrame.LightColor = Color3.fromRGB(255, 235, 200)
                vpFrame.LightDirection = Vector3.new(-1, -2, -1)
                                vpFrame.Parent = tile

                if item.Model then
                    task.spawn(function()
                        task.wait(order * 0.04) -- stagger clones to avoid frame spike
                        -- Accept Model instance or "workspace.Eggs.Basic" path string
                        local modelInst = nil
                        if typeof(item.Model) == "Instance" then
                            modelInst = item.Model
                        elseif type(item.Model) == "string" then
                            pcall(function()
                                local ref = game
                                for _, part in ipairs(item.Model:split(".")) do
                                    ref = ref:FindFirstChild(part) or ref[part]
                                end
                                modelInst = ref
                            end)
                        end
                        if not modelInst then return end

                        local ok, clone = pcall(function() return modelInst:Clone() end)
                        if not ok or not clone then return end

                        -- Strip non-visual descendants
                        for _, v in ipairs(clone:GetDescendants()) do
                            if v:IsA("Script") or v:IsA("LocalScript") or v:IsA("ModuleScript")
                            or v:IsA("ProximityPrompt") or v:IsA("ClickDetector")
                            or v:IsA("Sound") or v:IsA("ParticleEmitter") then
                                pcall(function() v:Destroy() end)
                            end
                        end
                        clone.Parent = vpFrame

                        -- Auto-frame camera to bounding box
                        local cam = Instance.new("Camera")
                        cam.FieldOfView = 45
                        local ok2, cf, size = pcall(function() return clone:GetBoundingBox() end)
                        if ok2 and cf then
                            local dist = math.max(size.X, size.Y, size.Z) * 2.2
                            cam.CFrame = CFrame.new(
                                cf.Position + Vector3.new(dist * 0.45, size.Y * 0.35, dist * 0.75),
                                cf.Position
                            )
                        end
                        cam.Parent = vpFrame
                        vpFrame.CurrentCamera = cam
                    end)
                end

                -- Title
                local titleLbl = Instance.new("TextLabel")
                titleLbl.Size = UDim2.new(1, -8, 0, 18)
                titleLbl.Position = UDim2.new(0, 4, 1, -42)
                titleLbl.BackgroundTransparency = 1
                titleLbl.Text = item.Title or ""
                titleLbl.TextSize = 11
                titleLbl.Font = Enum.Font.GothamBold
                titleLbl.TextXAlignment = Enum.TextXAlignment.Center
                titleLbl.TextTruncate = Enum.TextTruncate.AtEnd
                titleLbl.ZIndex = 2
                titleLbl.Parent = tile
                ThemeMethods.bindTheme(titleLbl, "TextColor3", "Foregrounds.Light")

                -- Subtitle
                local subLbl = Instance.new("TextLabel")
                subLbl.Size = UDim2.new(1, -8, 0, 14)
                subLbl.Position = UDim2.new(0, 4, 1, -24)
                subLbl.BackgroundTransparency = 1
                subLbl.Text = item.Subtitle or ""
                subLbl.TextSize = 10
                subLbl.Font = Enum.Font.Gotham
                subLbl.TextXAlignment = Enum.TextXAlignment.Center
                subLbl.TextTruncate = Enum.TextTruncate.AtEnd
                subLbl.ZIndex = 2
                subLbl.Parent = tile
                ThemeMethods.bindTheme(subLbl, "TextColor3", "Foregrounds.Medium")

                -- Hover
                tile.MouseEnter:Connect(function()
                    Tween(tile, { BackgroundColor3 = EliteUI.CurrentTheme.Backgrounds.Highlight })
                    Tween(tileStroke, { Color = EliteUI.CurrentTheme.Foregrounds.Medium })
                end)
                tile.MouseLeave:Connect(function()
                    Tween(tile, { BackgroundColor3 = EliteUI.CurrentTheme.Backgrounds.Groupbox })
                    Tween(tileStroke, { Color = EliteUI.CurrentTheme.Foregrounds.Dark })
                end)

                -- Click тАФ accent flash + callback
                tile.MouseButton1Click:Connect(function()
                    Tween(tileStroke, { Color = EliteUI.CurrentTheme.Foregrounds.Active })
                    task.delay(0.35, function()
                        pcall(function()
                            Tween(tileStroke, { Color = EliteUI.CurrentTheme.Foregrounds.Dark })
                        end)
                    end)
                    if item.Callback then pcall(item.Callback) end
                end)

                return tile
            end

            -- Build initial tiles
            for i, item in ipairs(items or {}) do
                tileFrames[i] = buildTile(item, i)
            end

            -- Returned grid handle
            local Grid = {}
            Grid.SelectedItem  = nil
            Grid.SelectedItems = {}

            function Grid:Refresh(newItems)
                Grid.SelectedItem  = nil
                Grid.SelectedItems = {}
                if infoLabel then infoLabel.Text = selectLabel end
                for _, f in ipairs(tileFrames) do
                    pcall(function() f:Destroy() end)
                end
                tileFrames = {}
                for i, item in ipairs(newItems or {}) do
                    tileFrames[i] = buildTile(item, i)
                end
            end

            function Grid:Destroy()
                pcall(function() scrollFrame:Destroy() end)
                pcall(function() gb:Destroy() end)
            end

            return Grid
        end

        return TabWrapper
    end

    -- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР

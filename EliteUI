local LucideIcons = nil
local _iconsReady = false
-- Queue of {imageLabel, iconInput} calls made before icons loaded
local _iconQueue = {}

-- Load Lucide icons asynchronously тАФ does NOT block script startup
task.spawn(function()
	pcall(function()
		if not isStudio then
			local iconSrc = game:HttpGet('https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/refs/heads/main/icons.lua')
			if iconSrc and #iconSrc > 0 then
				LucideIcons = loadstring(iconSrc)()
			end
		end
	end)
	_iconsReady = true
	-- Flush any queued icon calls that arrived before icons were ready
	for _, queued in ipairs(_iconQueue) do
		pcall(function()
			local lbl, inp = queued[1], queued[2]
			if lbl and lbl.Parent then -- still alive
				local sizedIcons = LucideIcons and LucideIcons['48px']
				if sizedIcons then
					local name = string.match(string.lower(inp), "^%s*(.*)%s*$")
					local entry = sizedIcons[name]
					if entry then
						lbl.Image = "rbxassetid://" .. entry[1]
						if entry[2] then lbl.ImageRectSize   = Vector2.new(entry[2][1], entry[2][2]) end
						if entry[3] then lbl.ImageRectOffset = Vector2.new(entry[3][1], entry[3][2]) end
					end
				end
			end
		end)
	end
	_iconQueue = {}
end)

-- Universal icon setter: handles both numeric asset IDs and Lucide string names
-- Sets Image, ImageRectOffset, ImageRectSize on any ImageLabel/ImageButton
local function setIcon(imageLabel, iconInput)
	if not imageLabel then return end
	-- Reset rect properties
	imageLabel.ImageRectOffset = Vector2.new(0, 0)
	imageLabel.ImageRectSize = Vector2.new(0, 0)

	if iconInput == nil or iconInput == "" then
		imageLabel.Image = ""
		return
	end

	-- Numeric asset ID (number or numeric string)
	if type(iconInput) == "number" then
		imageLabel.Image = "rbxassetid://" .. iconInput
		return
	end

	if type(iconInput) == "string" then
		-- Already a numeric asset ID string
		if tonumber(iconInput) then
			imageLabel.Image = "rbxassetid://" .. iconInput
			return
		end

		-- Lucide icon name lookup
		if LucideIcons then
			local sizedIcons = LucideIcons['48px']
			if sizedIcons then
				local name = string.match(string.lower(iconInput), "^%s*(.*)%s*$")
				local entry = sizedIcons[name]
				if entry then
					imageLabel.Image = "rbxassetid://" .. entry[1]
					if entry[2] then
						imageLabel.ImageRectSize = Vector2.new(entry[2][1], entry[2][2])
					end
					if entry[3] then
						imageLabel.ImageRectOffset = Vector2.new(entry[3][1], entry[3][2])
					end
					return
				end
			end
		end

		-- Icons not ready yet and this is a named icon тАФ queue it for when they load
		if not _iconsReady and #iconInput > 0 and not tonumber(iconInput) then
			table.insert(_iconQueue, {imageLabel, iconInput})
			return
		end

		-- Fallback: try as raw asset ID anyway
		if #iconInput > 0 then
			imageLabel.Image = "rbxassetid://" .. iconInput
		else
			imageLabel.Image = ""
		end
	end
end


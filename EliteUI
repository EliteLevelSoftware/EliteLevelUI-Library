-- Returns an array of all built-in theme names
function EliteUI:GetThemes()
	local list = {}
	for name, _ in pairs(Themes) do
		table.insert(list, name)
	end
	table.sort(list)
	return list
end

-- Returns the Themes table directly (for advanced users)
function EliteUI:GetThemeTable()
	return Themes
end

-- Returns the currently active theme name (or nil if custom)
function EliteUI:GetCurrentThemeName()
	if EliteUI._currentThemeName then return EliteUI._currentThemeName end
	if not EliteUI.CurrentTheme then return nil end
	for name, theme in pairs(Themes) do
		if theme.Backgrounds and EliteUI.CurrentTheme.Backgrounds
			and theme.Backgrounds.Dark == EliteUI.CurrentTheme.Backgrounds.Dark
			and theme.Backgrounds.Medium == EliteUI.CurrentTheme.Backgrounds.Medium
			and theme.Backgrounds.Light == EliteUI.CurrentTheme.Backgrounds.Light then
			return name
		end
	end
	return nil
end

-- Helper: Creates a theme selector dropdown in a given Tab/Groupbox
-- Usage: EliteUI:CreateThemeSelector(Tab, { Column = 1, IncludeTransparency = true })
-- Or through Rayfield wrapper: Rayfield:CreateThemeSelector(Tab, Settings)
function EliteUI:CreateThemeSelector(targetTab, settings)
	settings = settings or {}
	local column = settings.Column or 1
	local includeTransparency = settings.IncludeTransparency ~= false -- default true
	local callback = settings.Callback or function() end

	-- Get all theme names
	local themeNames = EliteUI:GetThemes()

	-- Find current theme for default
	local currentName = EliteUI:GetCurrentThemeName() or "Default"

	-- Create a groupbox if a groupbox method exists on the target
	local container = targetTab
	if targetTab.CreateGroupbox then
		container = targetTab:CreateGroupbox({
			Name = settings.GroupboxName or "Appearance",
			Icon = settings.GroupboxIcon or 6031625148,
			Column = column,
		})
	end

	-- Theme dropdown
	local themeDropdown = container:CreateDropdown({
		Name = "Theme",
		CurrentOption = { currentName },
		Options = themeNames,
		MultiSelection = false,
		Callback = function(selected)
			local themeName = selected[1] or selected
			if Themes[themeName] then
				EliteUI:SetTheme(themeName)
				EliteUI:SaveWindowState()
				callback(themeName)
			end
		end,
	})

	-- Transparency slider
	local transparencySlider = nil
	if includeTransparency then
		local currentT = transparencyOverride or (EliteUI.CurrentTheme and EliteUI.CurrentTheme.Transparency) or 0
		transparencySlider = container:CreateSlider({
			Name = "Transparency",
			CurrentValue = math.floor(currentT * 100),
			Range = {0, 80},
			Increment = 5,
			Suffix = "%",
			Callback = function(val)
				EliteUI:SetTransparency(val / 100)
				EliteUI:SaveWindowState()
			end,
		})
	end

	return {
		Dropdown = themeDropdown,
		Slider = transparencySlider,
	}
end


				ThemeMethods.bindTheme(fadetop.UIGradient, "Color", "Backgrounds.Dark")
				ThemeMethods.bindTheme(fadebottom.UIGradient, "Color", "Backgrounds.Dark")

				local basetrans = 0

				local function updTop()
					if column.CanvasPosition.Y ~= 0 then

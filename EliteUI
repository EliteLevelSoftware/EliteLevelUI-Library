		function TabSection:CreateCustomTab(TabSettings, TabIndex)
			-- Tab Settings Table
			--[[

			TabSettings = {
				Name = string,
				Columns = number, (ranged from 1-3)
				Icon = number/string, **
			}

			]]

			TabSettings.Icon = TabSettings.Icon or ""

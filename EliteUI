		if EliteUI.Window then
			EliteUI.Window.CurrentSize = mainWindow.Size
		end
		-- Apply saved/default transparency now that the window is ready
		pcall(function() transparencyEvent:Fire() end)
	end)

	-- Return the window
	return EliteUI.Window
end

function EliteUI.FileSystem:BuildFolderTree(FileSettings)
	-- Revamp since beta 4 since we are storing stuff within like scripts for both themes and such
	if isStudio or not isfolder then
		return "Config system unavailable."
	end
	if not FileSettings or not FileSettings.ConfigFolder then
		pcall(function()
			if not isfolder(EliteUI.FileSystem.Folder) then
				makefolder(EliteUI.FileSystem.Folder)
			end
		end)
		return
	end
	local paths = {}
	if FileSettings.RootFolder ~= nil then
		-- has root
		if FileSettings.ThemesInRoot then
			paths = {
				EliteUI.FileSystem.Folder,
				`{EliteUI.FileSystem.Folder}/{FileSettings.RootFolder}/{FileSettings.ConfigFolder}`,
				`{EliteUI.FileSystem.Folder}/{FileSettings.RootFolder}/{FileSettings.ConfigFolder}/configs`,
				`{EliteUI.FileSystem.Folder}/{FileSettings.RootFolder}/themes`,
			}
		else
			paths = {
				EliteUI.FileSystem.Folder,
				`{EliteUI.FileSystem.Folder}/{FileSettings.RootFolder}/{FileSettings.ConfigFolder}`,
				`{EliteUI.FileSystem.Folder}/{FileSettings.RootFolder}/{FileSettings.ConfigFolder}/configs`,
				`{EliteUI.FileSystem.Folder}/{FileSettings.RootFolder}}/{FileSettings.ConfigFolder}/themes`,
			}
		end
	else
		-- no root
		paths = {
			EliteUI.FileSystem.Folder,
			`{EliteUI.FileSystem.Folder}/{FileSettings.ConfigFolder}`,
			`{EliteUI.FileSystem.Folder}/{FileSettings.ConfigFolder}/configs`,
			`{EliteUI.FileSystem.Folder}/{FileSettings.ConfigFolder}/themes`,
		}
	end

	for i, str in ipairs(paths) do

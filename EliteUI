                Name = "Copy Discord Invite",
                Callback = function()
                    pcall(function() setclipboard("https://discord.gg/" .. Settings.DiscordInvite) end)
                    if Request then
                        pcall(function()
                            Request({
                                Url = "http://127.0.0.1:6463/rpc?v=1",
                                Method = "POST",
                                Headers = {
                                    ["Content-Type"] = "application/json",
                                    Origin = "https://discord.com",

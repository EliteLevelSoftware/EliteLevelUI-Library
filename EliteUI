            local delta = input.Position - subResizeStart
            local rt = subResizeType
            local newW, newH = subStartSize.X, subStartSize.Y
            local newX, newY = subStartPos.X,  subStartPos.Y
            if rt=="right" or rt=="br" or rt=="tr" then newW = math.max(SUB_MIN_W, subStartSize.X+delta.X) end
            if rt=="bottom" or rt=="br" or rt=="bl" then newH = math.max(SUB_MIN_H, subStartSize.Y+delta.Y) end
            if rt=="left" or rt=="bl" or rt=="tl" then

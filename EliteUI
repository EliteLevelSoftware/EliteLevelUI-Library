					if not Dragging then
						Tween(
							dragBarCosmetic,
							{ BackgroundTransparency = 0.5, Size = UDim2.new(0, 120, 0, 4) },
							nil,
							TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

			ThemeMethods.bindTheme(Tab.Instances.Button.Header, "TextColor3", "Foregrounds.Medium")
			themeEvent.Event:Connect(function()
				if tabs.UIPageLayout.CurrentPage == Tab.Instances.Page then
					Activate()
				end
			end)

